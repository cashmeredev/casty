#!/bin/bash
# casty - TTY web browser
# シェルラッパー: Chromium 管理 + 本体起動

# シンボリックリンクを解決して実際のパスを取得
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
CASTY_DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

export PLAYWRIGHT_BROWSERS_PATH="$HOME/.casty/browsers"
STAMP="$HOME/.casty/.update-check"

# Chromium headless shell インストール
install_chromium() {
  npx --prefix "$CASTY_DIR" playwright install chromium-headless-shell 2>&1 | grep -v "^$" >&2
  touch "$STAMP"
}

# 古いブラウザバージョンを削除 (最新1つだけ残す)
cleanup_old_browsers() {
  local count=$(ls -d "$PLAYWRIGHT_BROWSERS_PATH"/*/ 2>/dev/null | wc -l)
  [ "$count" -le 1 ] && return
  # 最も古いディレクトリを削除
  local oldest=$(ls -t -d "$PLAYWRIGHT_BROWSERS_PATH"/*/ 2>/dev/null | tail -1)
  [ -n "$oldest" ] && rm -rf "$oldest"
}

# 初回: ブラウザがなければインストール (ブロッキング)
if [ ! -d "$PLAYWRIGHT_BROWSERS_PATH" ] || [ -z "$(ls -A "$PLAYWRIGHT_BROWSERS_PATH" 2>/dev/null)" ]; then
  echo "casty: Installing Chromium (first run)..." >&2
  install_chromium
fi

# 1日1回だけバックグラウンドで更新チェック (既存を消さずにインストール→古いのを掃除)
needs_update() {
  [ ! -f "$STAMP" ] && return 0
  local last=$(stat -c %Y "$STAMP" 2>/dev/null || stat -f %m "$STAMP" 2>/dev/null || echo 0)
  local now=$(date +%s)
  [ $(( now - last )) -gt 86400 ]
}

if needs_update; then
  (install_chromium && cleanup_old_browsers) &>/dev/null &
fi

exec node "$CASTY_DIR/bin/casty.js" "$@"
