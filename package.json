{
  "name": "casty",
  "version": "0.1.0",
  "description": "TTY web browser using Playwright and Kitty graphics protocol",
  "main": "bin/casty.js",
  "bin": {
    "casty": "./bin/casty"
  },
  "scripts": {
    "start": "./bin/casty",
    "postinstall": "echo 'Run ./bin/casty to auto-install Chromium to ~/.casty/browsers/'"
  },
  "keywords": [
    "browser",
    "tty",
    "terminal",
    "kitty",
    "playwright",
    "headless",
    "chrome"
  ],
  "author": "Hironobu Sano",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "playwright": "^1.40.0"
  }
}
